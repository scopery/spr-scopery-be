# ===============================
# Spring Profile
# ===============================

SPRING_PROFILES_ACTIVE=local

# ===============================
# Database
# ===============================

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/scopery
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# ===============================
# Redis
# ===============================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===============================
# JWT
# ===============================

# Secret must be at least 32 characters (256 bits) for HS256.
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-256-bit-secret-key-before-deploying

# Access token TTL in milliseconds (default: 900000 = 15 minutes)
JWT_EXPIRATION_MS=900000

# Refresh token TTL in milliseconds (default: 604800000 = 7 days)
JWT_REFRESH_EXPIRATION_MS=604800000

# Set to false for local development over plain HTTP
JWT_COOKIE_SECURE=false

# ===============================
# CORS
# ===============================

# Explicit allowed frontend origins (comma-separated). Never use "*".
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=3600

# ===============================
# Rate Limiting
# ===============================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=300
RATE_LIMIT_WINDOW_SECONDS=60

# ===============================
# Scopery Secret Encryption
# ===============================

# Base64 encoded 256-bit (32-byte) AES master key.
# Generate: openssl rand -base64 32
SCOPERY_SECRET_MASTER_KEY=change-me-to-a-random-aes-master-key

# Key version label stored alongside each encrypted secret (default: v1).
# Increment when rotating to a new master key.
SCOPERY_SECRET_KEY_VERSION=v1

# ===============================
# Object Storage (MinIO / S3-compatible)
# ===============================

# Docker Compose: MinIO root credentials (used by minio + minio-init containers)
MINIO_ROOT_USER=scopery
MINIO_ROOT_PASSWORD=scopery-local-secret

# Application storage config (MINIO_ACCESS_KEY/SECRET_KEY must match root credentials for local)
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=scopery-local
MINIO_ACCESS_KEY=scopery
MINIO_SECRET_KEY=scopery-local-secret

# Presigned URL expiry (minutes)
STORAGE_PRESIGNED_UPLOAD_EXPIRY_MINUTES=10
STORAGE_PRESIGNED_DOWNLOAD_EXPIRY_MINUTES=5

# Max single file upload size in bytes (default: 104857600 = 100 MB)
STORAGE_MAX_UPLOAD_SIZE_BYTES=104857600

# ===============================
# OpenAI
# ===============================

# Required for: vector embeddings (knowledge indexing) + AI assistant chat
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Base URL — override when using Azure OpenAI or a compatible proxy
# OPENAI_BASE_URL=https://api.openai.com/v1

# HTTP timeout in seconds for OpenAI calls (default: 60)
# OPENAI_TIMEOUT_SECONDS=60

# ===============================
# AI Agent Runtime
# ===============================

# Controls which event configurations are resolved during execution.
# Allowed values: DEV | UAT | PROD
AIAGENT_RUNTIME_ENVIRONMENT=DEV

# Enable/disable the playground feature
AIAGENT_PLAYGROUND_ENABLED=true

# Prevent lifecycle state writes (RUNNING/SUCCEEDED/FAILED) from outside the execution engine
AIAGENT_EXECUTION_RESTRICT_LIFECYCLE_WRITES=true

# ===============================
# AI Assistant (Chat)
# ===============================

# Prompt profile code — must match a seeded AI agent event configuration
AI_ASSISTANT_PROMPT_PROFILE=SCOPERY_CONTEXTUAL_ASSISTANT_V1

# SSE emitter timeout (ISO-8601 duration)
AI_ASSISTANT_EMITTER_TIMEOUT=180s

# Heartbeat interval to keep SSE connections alive
AI_ASSISTANT_HEARTBEAT_INTERVAL=15s

# How long stream events are retained in Redis
AI_ASSISTANT_STREAM_EVENT_RETENTION=24h

# How long conversations are retained before soft-delete
AI_ASSISTANT_CONVERSATION_RETENTION=180d

# How long after soft-delete before purge
AI_ASSISTANT_DELETED_PURGE_DELAY=30d

# How long tool trace records are kept
AI_ASSISTANT_TOOL_TRACE_RETENTION=30d

# --- Safety / quota limits ---

# Max characters per user message
AI_ASSISTANT_MAX_USER_MESSAGE_CHARS=8000

# Max messages stored per conversation
AI_ASSISTANT_MAX_MESSAGES_PER_CONVERSATION=500

# Max input tokens per LLM call
AI_ASSISTANT_MAX_INPUT_TOKENS=24000

# Max output tokens per LLM call
AI_ASSISTANT_MAX_OUTPUT_TOKENS=2000

# Max evidence/context chunks injected per call
AI_ASSISTANT_MAX_EVIDENCE_CHUNKS=8

# Max concurrent SSE streams per user
AI_ASSISTANT_MAX_ACTIVE_STREAMS=2

# Daily turn quota per user (across all conversations)
AI_ASSISTANT_MAX_TURNS_PER_DAY=200

# Daily token quota per user (input + output combined)
AI_ASSISTANT_MAX_TOKENS_PER_DAY=500000

# --- Memory compression thresholds ---

# Number of turns that triggers automatic summarization
AI_ASSISTANT_MEMORY_TRIGGER_TURNS=20

# Unsummarized token count that triggers summarization
AI_ASSISTANT_MEMORY_TRIGGER_TOKENS=12000

# Number of recent messages kept verbatim after summarization
AI_ASSISTANT_MEMORY_KEEP_MESSAGES=8

# Max tokens for the generated memory summary
AI_ASSISTANT_MEMORY_MAX_SUMMARY_TOKENS=2000

# --- Background jobs ---

# Cron for purging expired stream events from Redis (default: top of every hour)
AI_ASSISTANT_STREAM_PURGE_CRON=0 0 * * * *

# Cron for conversation retention/purge sweep (default: 03:00 daily)
AI_ASSISTANT_RETENTION_CRON=0 0 3 * * *

# Fixed delay (ms) for recovering stale/stuck streams (default: 5 minutes)
AI_ASSISTANT_STALE_RECOVERY_DELAY_MS=300000

# Fixed delay (ms) for the SSE heartbeat job
AI_ASSISTANT_HEARTBEAT_DELAY_MS=15000

# ===============================
# Knowledge Indexing
# ===============================

# Target token count per chunk for each source type
KNOWLEDGE_CHUNK_TASK_TARGET_TOKENS=600
KNOWLEDGE_CHUNK_DOCUMENT_TARGET_TOKENS=800
KNOWLEDGE_CHUNK_MEETING_TARGET_TOKENS=600

# ===============================
# Reporting
# ===============================

REPORTING_SNAPSHOT_RETENTION_DAYS=90
REPORTING_SNAPSHOT_RETENTION_ENABLED=true
# Cron: 02:45 daily
REPORTING_SNAPSHOT_RETENTION_CRON=0 45 2 * * *

# ===============================
# Platform — Outbox
# ===============================

PLATFORM_OUTBOX_ENABLED=true
PLATFORM_OUTBOX_BATCH_SIZE=50
PLATFORM_OUTBOX_MAX_ATTEMPTS=10
PLATFORM_OUTBOX_LOCK_SECONDS=60
PLATFORM_OUTBOX_FIXED_DELAY_MS=5000
PLATFORM_OUTBOX_BASE_RETRY_DELAY_SECONDS=30

# ===============================
# Platform — Idempotency
# ===============================

PLATFORM_IDEMPOTENCY_TTL_HOURS=24
PLATFORM_IDEMPOTENCY_IN_PROGRESS_LOCK_SECONDS=120
PLATFORM_IDEMPOTENCY_CLEANUP_ENABLED=true
PLATFORM_IDEMPOTENCY_CLEANUP_CRON=0 15 * * * *

# Require Idempotency-Key header on configured paths (false = optional)
PLATFORM_IDEMPOTENCY_REQUIRE_ENABLED=false
PLATFORM_IDEMPOTENCY_REQUIRE_PATHS=/api/projects/*/tasks,/api/projects/*/scope-packages,/api/projects/*/quotes

# ===============================
# Platform — Swagger / API Docs
# ===============================

# Set to false in production to disable Swagger UI
PLATFORM_SWAGGER_PUBLIC=true

# ===============================
# Workspace
# ===============================

# When true, access checks use effective (inherited) permissions.
# Set to false only when debugging permission issues.
WORKSPACE_USE_EFFECTIVE_ACCESS=true

# ===============================
# Notification — Email
# ===============================

# Set to true to enable email dispatch
NOTIFICATION_EMAIL_ENABLED=false

# Provider: LOG_ONLY | SMTP
NOTIFICATION_EMAIL_PROVIDER=LOG_ONLY

NOTIFICATION_EMAIL_FROM_ADDRESS=no-reply@local.test
NOTIFICATION_EMAIL_FROM_NAME=Scopery
APP_FRONTEND_BASE_URL=http://localhost:3000

# Outbox processor
NOTIFICATION_EMAIL_OUTBOX_ENABLED=true
NOTIFICATION_EMAIL_OUTBOX_BATCH_SIZE=20
NOTIFICATION_EMAIL_OUTBOX_MAX_RETRY=3
NOTIFICATION_EMAIL_OUTBOX_RETRY_DELAY_SECONDS=60
NOTIFICATION_EMAIL_OUTBOX_FIXED_DELAY_MS=10000

# ===============================
# SMTP (used when PROVIDER=SMTP)
# ===============================

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false

# ================================
# Bootstrap Admin User
# ================================

ADMIN_SEED_USERNAME=
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
