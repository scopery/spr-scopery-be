# ===============================
# Spring Profile
# ===============================

SPRING_PROFILES_ACTIVE=local

# ===============================
# Database
# ===============================

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/scopery
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# ===============================
# Redis
# ===============================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===============================
# JWT
# ===============================

# Secret must be at least 32 characters (256 bits) for HS256.
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-256-bit-secret-key-before-deploying

# Access token TTL in milliseconds (default: 900000 = 15 minutes)
JWT_EXPIRATION_MS=900000

# Refresh token TTL in milliseconds (default: 604800000 = 7 days)
JWT_REFRESH_EXPIRATION_MS=604800000

# Set to false for local development over plain HTTP
JWT_COOKIE_SECURE=false

# ===============================
# Rate Limiting
# ===============================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60

# ===============================
# Scopery Secret Encryption
# ===============================

# Base64 encoded 256-bit (32-byte) AES master key.
# Generate a local key by running:
#   openssl rand -base64 32
SCOPERY_SECRET_MASTER_KEY=change-me-to-a-random-aes-master-key

# Key version label stored alongside each encrypted secret (default: v1).
# Increment when rotating to a new master key.
SCOPERY_SECRET_KEY_VERSION=v1

# ===============================
# AI Agent Runtime
# ===============================

# Controls which event configurations are resolved during execution.
# Allowed values: DEV | UAT | PROD
AIAGENT_RUNTIME_ENVIRONMENT=DEV

# ===============================
# OpenAI Provider (optional overrides)
# ===============================

# Base URL for the OpenAI Responses API (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Timeout in seconds for OpenAI API calls (default: 60)
# OPENAI_TIMEOUT_SECONDS=60

# ===============================
# Notification — Email
# ===============================

# Set to true to enable email dispatch
NOTIFICATION_EMAIL_ENABLED=false

# Provider: LOG_ONLY | SMTP
NOTIFICATION_EMAIL_PROVIDER=LOG_ONLY

NOTIFICATION_EMAIL_FROM_ADDRESS=no-reply@local.test
NOTIFICATION_EMAIL_FROM_NAME=Scopery
APP_FRONTEND_BASE_URL=http://localhost:3000

# Outbox processor settings
NOTIFICATION_EMAIL_OUTBOX_ENABLED=true
NOTIFICATION_EMAIL_OUTBOX_BATCH_SIZE=20
NOTIFICATION_EMAIL_OUTBOX_MAX_RETRY=3
NOTIFICATION_EMAIL_OUTBOX_RETRY_DELAY_SECONDS=60
NOTIFICATION_EMAIL_OUTBOX_FIXED_DELAY_MS=10000

# ===============================
# SMTP (used when PROVIDER=SMTP)
# ===============================

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false

# ================================
# Bootstrap Admin User (optional)
# ================================
ADMIN_SEED_USERNAME=
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
